{
  "name": "@angelfive/backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express backend server for AngelFive project",
  "author": "Angel Five Team",
  "license": "MIT",
  "keywords": [
    "express",
    "typescript",
    "backend",
    "api"
  ],
  "main": "dist/server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "nodemon src/server.ts",
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc --build --force",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-validator": "^7.3.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^7.2.0",
    "morgan": "^1.10.1",
    "rimraf": "^5.0.10",
    "speakeasy": "^2.0.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.35",
    "@types/speakeasy": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
